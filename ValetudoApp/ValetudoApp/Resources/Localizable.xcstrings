    "update.warning_message": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ACHTUNG: Firmware-Updates sind riskant!\n\n• Nicht über VPN/instabile Verbindungen durchführen\n• Kann mehrere Minuten dauern\n• Roboter nicht vom Strom trennen\n• Bei Fehlschlag muss ggf. neu gerootet werden\n\nBist du sicher?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WARNING: Firmware updates are risky!\n\n• Do not use VPN or unstable connections\n• May take several minutes\n• Do not disconnect power\n• Failed updates may require re-rooting\n\nAre you sure?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ATTENTION : les mises à jour du firmware comportent des risques !\n\n• Ne pas effectuer via VPN ou connexion instable\n• Peut prendre plusieurs minutes\n• Ne pas débrancher pendant la mise à jour"
          }
        }
      }
    },
