{
  "sourceLanguage": "en",
  "strings": {
    ":": {
      "comment": "A colon character used in time pickers.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": ":"
          }
        }
      }
    },
    "·": {
      "comment": "A period used to separate related pieces of information.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "."
          }
        }
      }
    },
    "%@": {
      "comment": "A badge indicating the number of selected rooms.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@"
          }
        }
      }
    },
    "%@ - %@": {
      "comment": "Displays the current active time period of the Do Not Disturb feature. The format is \"HH:mm - HH:mm\".",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ - %2$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ - %2$@"
          }
        }
      }
    },
    "%@ / %@": {
      "comment": "A label displaying the total and free memory of the device, separated by a slash. The first argument is the string “%.1f GB” or the string “%.1f MB”. The second argument is the string “%.1f GB” or the string “%.1f MB”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ / %2$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ / %2$@"
          }
        }
      }
    },
    "%@ → %@": {
      "comment": "A detail line showing the current version of Valetudo and the version available for update.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ → %2$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ → %2$@"
          }
        }
      }
    },
    "%@ dBm": {
      "comment": "A sublabel within the current connection section showing the signal strength of the Wi-Fi connection. The argument is the signal strength, expressed in decibels minus meters (dBm).",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ dBm"
          }
        }
      }
    },
    "%@ ms": {
      "comment": "A label displaying the offset of the robot's clock relative to the world clock. The value is shown in milliseconds.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ms"
          }
        }
      }
    },
    "%@%%": {
      "comment": "A text field displaying the battery level of a robot. The argument is the battery level as a percentage.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@%%"
          }
        }
      }
    },
    "%@×": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@×"
          }
        }
      }
