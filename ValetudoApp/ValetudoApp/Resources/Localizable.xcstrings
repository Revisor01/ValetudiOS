    "support.message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Software sollte frei sein.\n\nWenn du es dir gerade leisten kannst, freue ich mich über deine Unterstützung. Ansonsten nutze die App einfach gerne – das ist völlig in Ordnung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Software should be free.\n\nIf you can afford it right now, I'd appreciate your support. Otherwise, just enjoy using the app – that's totally fine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le logiciel devrait être libre.\n\nSi vous le pouvez, votre soutien m'aiderait beaucoup."
          }
        }
      }
    },
    "support.reminder.already": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hab ich schon"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Already Did"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déjà fait"
          }
        }
      }
    },
    "support.reminder.later": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerade nicht"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not Now"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas maintenant"
          }
        }
      }
    },
    "support.reminder.message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App ist kostenlos und werbefrei. Sie wurde mit viel Liebe entwickelt.\n\nSoftware sollte frei sein. Wenn du es dir leisten kannst, unterstütze die Entwicklung gerne. Ansonsten nutze die App einfach weiter – das ist völlig okay!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is free and ad-free. It was built with love.\n\nSoftware should be free. If you can afford it, please consider supporting the development. Otherwise, just keep using the app – that's totally okay!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app est gratuite et sans publicité. Elle a été développée avec beaucoup d'amour.\n\nLe logiciel devrait être libre. Si vous le pouvez, je serais ravi de votre soutien. Sinon, profitez simplement de l'app."
          }
        }
      }
    },
